# Gianluigi Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# Claude API
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...
# Optional tiered models (fall back to CLAUDE_MODEL if unset)
# CLAUDE_MODEL_EXTRACTION=claude-opus-4-6
# CLAUDE_MODEL_AGENT=claude-sonnet-4-6
# CLAUDE_MODEL_BACKGROUND=claude-sonnet-4-6
# CLAUDE_MODEL_SIMPLE=claude-haiku-4-5-20251001

# =============================================================================
# Supabase (PostgreSQL + pgvector)
# Create project at https://supabase.com - use EU region (Frankfurt)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key  # MUST be service_role key (not anon) — RLS is enabled

# =============================================================================
# Google APIs (OAuth credentials)
# Set up via Google Cloud Console - see scripts/setup_google.md
# =============================================================================
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# =============================================================================
# Telegram Bot
# Create bot via @BotFather on Telegram
# Get chat IDs: Send /start to bot, then check:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_CHAT_ID=
TELEGRAM_EYAL_CHAT_ID=

# Team Telegram IDs (for direct task reminders)
EYAL_TELEGRAM_ID=
ROYE_TELEGRAM_ID=
PAOLO_TELEGRAM_ID=
YORAM_TELEGRAM_ID=

# =============================================================================
# Gmail
# Dedicated Gmail for Gianluigi
# =============================================================================
GIANLUIGI_EMAIL=gianluigi.cropsight@gmail.com

# =============================================================================
# Google Drive Folder IDs
# Get from folder URLs: https://drive.google.com/drive/folders/[ID]
# =============================================================================
CROPSIGHT_OPS_FOLDER_ID=
RAW_TRANSCRIPTS_FOLDER_ID=
MEETING_SUMMARIES_FOLDER_ID=
MEETING_PREP_FOLDER_ID=
WEEKLY_DIGESTS_FOLDER_ID=
DOCUMENTS_FOLDER_ID=

# =============================================================================
# Google Sheets IDs
# Get from sheet URLs: https://docs.google.com/spreadsheets/d/[ID]
# =============================================================================
TASK_TRACKER_SHEET_ID=
STAKEHOLDER_TRACKER_SHEET_ID=

# =============================================================================
# Embeddings (OpenAI for text-embedding-3-small)
# =============================================================================
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# Team Email Configuration
# =============================================================================
EYAL_EMAIL=
ROYE_EMAIL=
PAOLO_EMAIL=
YORAM_EMAIL=

# =============================================================================
# Calendar Configuration
# Purple color ID for CropSight meetings (get via Google Calendar API)
# =============================================================================
CROPSIGHT_CALENDAR_COLOR_ID=

# =============================================================================
# Application Settings
# =============================================================================
LOG_LEVEL=INFO
ENVIRONMENT=development
# PORT=8080

# =============================================================================
# v1.0 — Gantt Integration
# =============================================================================
GANTT_SHEET_ID=
GANTT_BACKUP_FOLDER_ID=
# GANTT_MAX_CELLS_PER_PROPOSAL=20

# =============================================================================
# v1.0 — Email Intelligence
# =============================================================================
EYAL_PERSONAL_EMAIL=
EYAL_GMAIL_REFRESH_TOKEN=
# PERSONAL_CONTACTS_BLOCKLIST=email1@example.com,email2@example.com
# EMAIL_DAILY_SCAN_ENABLED=false
# EMAIL_DAILY_SCAN_HOUR=7
# EMAIL_MAX_SCAN_RESULTS=50
