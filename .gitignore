# =============================================================================
# Gianluigi .gitignore
# =============================================================================

# =============================================================================
# Environment & Secrets (CRITICAL - never commit these!)
# =============================================================================
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
token.json
service-account.json

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================================================
# Virtual Environments
# =============================================================================
venv/
.venv/
ENV/
env/
.env/

# =============================================================================
# Claude Code (local settings)
# =============================================================================
.claude/settings.local.json

# =============================================================================
# IDE & Editors
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# =============================================================================
# Testing
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# =============================================================================
# Type Checking
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json

# =============================================================================
# Logs & Debug
# =============================================================================
*.log
logs/
debug/

# =============================================================================
# OS Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Docker
# =============================================================================
.docker/

# =============================================================================
# Local Data & Caches
# =============================================================================
data/
cache/
*.cache
*.sqlite
*.db

# =============================================================================
# Temporary Files
# =============================================================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
tmpclaude-*
-p/

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/
*.ipynb

# =============================================================================
# Distribution & Packaging
# =============================================================================
*.manifest
*.spec

# =============================================================================
# Documentation Build
# =============================================================================
docs/_build/
site/
